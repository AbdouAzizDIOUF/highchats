import { SocialShareLimits } from '@app/components/saisie-parts/models/saisie-parts.model';

const CENT_RATIO = 100;

export function roundAmountApproximation(amount: number): number {
  return Math.round(amount * CENT_RATIO) / CENT_RATIO;
}

export function clampAmount(value: number, min: number, max: number): number {
  if (value < min) return min;
  if (value > max) return max;
  return value;
}

/**
 * Arrondit une valeur au multiple le plus proche d'un pas donné
 * Si le multiple supérieur dépasse maxAmount, retourne le multiple inférieur
 * @param value - La valeur à arrondir
 * @param step - Le pas (multiple)
 * @param maxAmount - Le montant maximum autorisé
 * @returns La valeur arrondie au multiple approprié
 */
export function snapToClosestMultiple(value: number, step: number, maxAmount?: number): number {
  const lowerMultiple = Math.floor(value / step) * step;
  const upperMultiple = Math.ceil(value / step) * step;

  // Si un maxAmount est défini et que le multiple supérieur le dépasse, on prend le multiple inférieur
  if (maxAmount !== undefined && upperMultiple > maxAmount) {
    return roundAmountApproximation(lowerMultiple);
  }

  // Sinon, on prend le multiple le plus proche
  const closestMultiple = value - lowerMultiple < upperMultiple - value ? lowerMultiple : upperMultiple;
  return roundAmountApproximation(closestMultiple);
}

/**
 * Normalise un montant en le limitant et l'arrondissant au multiple approprié
 * Si la valeur ajustée dépasse maxAmount, prend le multiple inférieur
 * @param value - Le montant à normaliser
 * @param data - Les limites des parts sociales
 * @returns Le montant normalisé
 */
export function normalizeAmount(value: number, data: SocialShareLimits): number {
  const clamped = clampAmount(value, data.miniAmount, data.maxAmount);
  return snapToClosestMultiple(clamped, data.shareAmount, data.maxAmount);
}

import {AllowedAmountData, SocialShareLimits} from '@app/components/saisie-parts/models/saisie-parts.model';

/**
 * Calcule les données des parts sociales (montants min/max, nombre de parts min/max)
 * @param minimumShareNumber - Nombre minimum de parts
 * @param remainingAmountToInvest - Montant restant à investir
 * @param shareAmount - Valeur d'une part
 * @returns Les limites des parts sociales
 */
export function computeShareData(
  minimumShareNumber: number,
  remainingAmountToInvest: number,
  shareAmount: number
): SocialShareLimits {
  return {
    shareAmount,
    miniAmount: minimumShareNumber * shareAmount,
    maxAmount: remainingAmountToInvest,
    minParts: minimumShareNumber,
    maxParts: Math.floor(remainingAmountToInvest / shareAmount)
  };
}

/**
 * Calcule le montant et le nombre de parts maximum autorisés selon le solde du compte
 * @param balance - Solde du compte
 * @param shareAmount - Valeur d'une part
 * @returns Les données du montant maximum autorisé
 */
export function computeAllowedAmountData(balance: number | undefined, shareAmount: number): AllowedAmountData {
  if (!balance || shareAmount <= 0) {
    return {
      maximumAllowedAmount: 0,
      maximumAllowedParts: 0
    };
  }

  const maximumAllowedParts = Math.floor(balance / shareAmount);

  return {
    maximumAllowedParts,
    maximumAllowedAmount: maximumAllowedParts * shareAmount
  };
}

/**
 * Calcule le nombre de parts sociales correspondant à un montant donné
 * @param amount - Le montant saisi
 * @param shareAmount - Valeur d'une part
 * @returns Le nombre de parts sociales
 */
export function computeSelectedShareAmount(amount: number, shareAmount: number): number {
  return Math.floor(amount / shareAmount);
}

export type HelperMessageType = 'inputErreur' | 'infoAmount'

export interface SocialShareLimits {
  shareAmount: number;
  miniAmount: number;
  maxAmount: number;
  minParts: number;
  maxParts: number;
}

export interface AllowedAmountData {
  maximumAllowedParts: number;
  maximumAllowedAmount: number;
}

import {ChangeDetectionStrategy, Component, computed, DestroyRef, effect, inject, signal} from '@angular/core';
import {CurrencyPipe} from '@angular/common';
import {Router} from '@angular/router';
import {FormControl, FormGroup, ReactiveFormsModule, Validators} from '@angular/forms';
import {takeUntilDestroyed, toSignal} from '@angular/core/rxjs-interop';
import {switchMap} from 'rxjs';
import {NeoTextHelperComponent} from '@bpce/neo-ng/text-helper';
import {InformationPromptLayoutComponent} from '@bpce/ng-subscription-ui/information-prompt-layout';
import {NeoButtonComponent, NeoButtonGroupComponent} from '@bpce/neo-ng/button';
import {NeoSliderComponent} from '@bpce/neo-ng/slider';
import {NeoCardComponent} from '@bpce/neo-ng/card';
import {NeoDialogModule, NeoDialogService} from '@bpce/neo-ng/dialog';
import {NeoInputAmountComponent} from '@bpce/neo-ng/input-amount';
import {NeoShimmeringComponent} from '@bpce/neo-ng/shimmering';
import {StepRouteEnum} from '@app/routes';
import {BapiStoreService} from '@app/services/store/bapi.store.service';
import {InputStoreService} from '@app/services/store/input.store.service';
import {DigitalParameters} from '@app/models/digital-parameters';
import {SAISIE_PART_PAGE_DATALAYER} from '@app/constants/tracking/tracking.constant';
import {TrackingService} from '@bpce/ng-subscription-services/tracking';
import {BapiStore} from '@bpce/ng-subscription-services/bapi/store';
import {NestedKeys, WordingPipe} from '@bpce/ng-subscription-ui/utils';
import {PdfViewModalComponent} from '../modals/pdf-view-modal/pdf-view.modal.component';
import {UpdateAmountModalComponent} from '../modals/update-amount-modal/update-amount.modal.component';
import {SAISIE_PARTS_WORDING} from '@app/constants/wording/saisie-parts-wording.constant';
import {computeAllowedAmountData, computeSelectedShareAmount, computeShareData} from '@app/components/saisie-parts/utils/share-data.utils';
import {HelperMessageType, SocialShareLimits} from '@app/components/saisie-parts/models/saisie-parts.model';
import {normalizeAmount} from '@app/components/saisie-parts/utils/amount-normalization.utils';

@Component({
  selector: 'app-saisie-parts',
  templateUrl: './saisie-parts.component.html',
  styleUrl: './saisie-parts.component.scss',
  changeDetection: ChangeDetectionStrategy.OnPush,
  imports: [
    InformationPromptLayoutComponent,
    NeoButtonComponent,
    NeoButtonGroupComponent,
    NeoSliderComponent,
    NeoTextHelperComponent,
    ReactiveFormsModule,
    NeoCardComponent,
    NeoDialogModule,
    NeoInputAmountComponent,
    WordingPipe,
    CurrencyPipe,
    NeoShimmeringComponent
  ]
})
export class SaisiePartsComponent {
  readonly template = SAISIE_PARTS_WORDING;

  private readonly bapiStore = inject(BapiStoreService);
  private readonly inputStore = inject(InputStoreService);
  private readonly bapiStoreParam: BapiStore<DigitalParameters> = inject(BapiStore);


  // Signals d'état
  readonly isInputFocused = signal(false);
  readonly showShimmering = signal(false);
  readonly rawInputValue = signal<number | null>(null);
  readonly initialFocusedValue = signal<number | null>(null);
  readonly helperMessageType = signal<HelperMessageType>('infoAmount');

  readonly formGroup = new FormGroup({
    input: new FormControl<number | null>(null, {
      validators: [Validators.required, Validators.min(1)]
    })
  });

  private readonly inputControl = this.formGroup.controls.input;

  readonly formValue = toSignal(this.formGroup.valueChanges, {
    initialValue: this.formGroup.getRawValue()
  });

  readonly inputValue = computed(() => this.formValue().input ?? null);

  // Computed signals pour les données dérivées
  readonly shareData = computed((): SocialShareLimits | null => {
    const condition = this.bapiStore.conditionSocialShare.value();
    const selectedAccount = this.bapiStore.selectedAccount();

    if (!condition || !selectedAccount) {
      return null;
    }

    return computeShareData(
      condition.characteristics.minimumShareNumber,
      condition.characteristics.remainingAmountToInvest.value,
      selectedAccount.shareAmount.value
    );
  });

  readonly allowedAmountData = computed(() => {
    const data = this.shareData();
    const balance = this.inputStore.accountSelected()?.balance;

    if (!data) {
      return {
        maximumAllowedAmount: 0,
        maximumAllowedParts: 0
      };
    }

    return computeAllowedAmountData(balance, data.shareAmount);
  });

  readonly selectedShareAmount = computed(() => {
    const data = this.shareData();
    const value = this.inputValue();

    if (!data || value == null) {
      return 0;
    }

    return computeSelectedShareAmount(value, data.shareAmount);
  });

  readonly helperState = computed(() => {
    const data = this.shareData();
    const messageType = this.helperMessageType();

    if (!data) {
      return {
        display: false,
        key: 'form.helper.infoAmount' as NestedKeys<typeof SAISIE_PARTS_WORDING>,
        amount: 0
      };
    }

    return {
      display: messageType === 'inputErreur',
      key: messageType === 'inputErreur'
        ? 'form.helper.inputErreur' as NestedKeys<typeof SAISIE_PARTS_WORDING>
        : 'form.helper.infoAmount' as NestedKeys<typeof SAISIE_PARTS_WORDING>,
      amount: data.shareAmount
    };
  });

  readonly showValue = computed(() => {
    const data = this.shareData();
    const value = this.inputValue();
    return !!data && value != null && value > data.miniAmount;
  });

  readonly precision = computed(() => {
    const data = this.shareData();
    const selectedShareAmount = this.selectedShareAmount();

    if (data && Number.isInteger(selectedShareAmount * data.shareAmount) && !this.isInputFocused()) {
      return 0;
    }

    return 2;
  });

  readonly titleKey = computed((): NestedKeys<typeof SAISIE_PARTS_WORDING> => {
    const data = this.shareData();
    const inputValue = this.inputValue();

    if (!data || inputValue == null || inputValue <= data.miniAmount) {
      return 'header.title.default';
    }

    return this.showShimmering() ? 'header.title.editedShimmering' : 'header.title.edited';
  });


  readonly supportsPdfViewer = signal('pdfViewerEnabled' in navigator ? navigator.pdfViewerEnabled : false);
  readonly getNoticeLink = computed(() => this.bapiStoreParam.digitalParameters.value()?.links.technicalNoticeLink);

  constructor(private readonly trackingService: TrackingService,
              private readonly neoDialog: NeoDialogService,
              private readonly destroyRef: DestroyRef,
              private readonly router: Router) {

    effect(() => {
      const value = this.inputValue();
      const isFocused = this.isInputFocused();

      if (!isFocused) {
        return;
      }

      this.rawInputValue.set(value);
      this.showShimmering.set(value !== this.initialFocusedValue());
    });

    effect(() => {
      this.trackPage();
      this.initShares();
    });
  }

  onInputFocus(): void {
    const currentValue = this.inputValue();
    this.isInputFocused.set(true);
    this.initialFocusedValue.set(currentValue);
  }

  onValueBlur(): void {
    const data = this.shareData();
    const rawValue = this.rawInputValue();

    this.showShimmering.set(false);
    this.isInputFocused.set(false);
    this.initialFocusedValue.set(null);
    this.rawInputValue.set(null);

    if (!data || rawValue == null) {
      return;
    }

    const normalizedAmount = normalizeAmount(rawValue, data);

    // Ne change le message QUE si un ajustement a été fait
    if (normalizedAmount !== rawValue) {
      this.helperMessageType.set('inputErreur');
      this.inputControl.setValue(normalizedAmount);
    }
  }

  onSliderChange(value: number): void {
    const data = this.shareData();

    if (!data) {
      return;
    }

    const shouldAdjustMaximumValue = value === data.maxAmount && (value % data.shareAmount !== 0);
    const adjustedValue = shouldAdjustMaximumValue ? normalizeAmount(value, data) : value;

    this.inputControl.setValue(adjustedValue);
    this.inputControl.markAsDirty();

    this.helperMessageType.set(shouldAdjustMaximumValue ? 'inputErreur' : 'infoAmount');
    this.showShimmering.set(false);
    this.rawInputValue.set(null);
    this.initialFocusedValue.set(null);
    this.isInputFocused.set(false);
  }


  clear(): void {
    const data = this.shareData();

    if (!data) {
      return;
    }

    this.inputControl.reset(data.miniAmount);
    this.showShimmering.set(false);
    this.rawInputValue.set(null);
    this.initialFocusedValue.set(null);
    this.helperMessageType.set('infoAmount');
    this.isInputFocused.set(false);
  }

  openTechnicalNotice(): void {
    this.neoDialog
      .open(PdfViewModalComponent)
      .pipe(
        switchMap((ref) => ref.afterClose()),
        takeUntilDestroyed(this.destroyRef)
      )
      .subscribe();
  }

  onContinue(): void {
    const data = this.shareData();
    const value = this.inputControl.value;
    const balance = this.inputStore.accountSelected()?.balance;

    if (!data || value == null) {
      return;
    }

    // Vérification du dépassement du montant maximum
    if (balance && (value > data.maxAmount || value > balance)) {
      const allowed = this.allowedAmountData();

      this.neoDialog
        .open(UpdateAmountModalComponent, {
          data: {
            maximumAllowedAmount: allowed.maximumAllowedAmount,
            maximumAllowedParts: allowed.maximumAllowedParts
          }
        })
        .pipe(
          switchMap((ref) => ref.afterClose()),
          takeUntilDestroyed(this.destroyRef)
        )
        .subscribe();

      return;
    }

    const selectedShareAmount = Math.min(Math.max(this.selectedShareAmount(), data.minParts), data.maxParts);

    this.inputStore.setShareNumberSelected(selectedShareAmount);
    this.router.navigate([StepRouteEnum.QUESTION_INTRO]);
  }

  private initShares(): void {
    const shareNumber = this.inputStore.shareNumber();
    const data = this.shareData();

    if (!data || !shareNumber || shareNumber <= 0) {
      this.inputControl.setValue(data?.miniAmount ?? null);
      return;
    }

    this.inputControl.setValue(shareNumber * data.shareAmount);
    this.inputControl.markAsDirty();
  }


  private trackPage(): void {
    this.trackingService.trackPage(SAISIE_PART_PAGE_DATALAYER);
  }
}


@let data = shareData();

@if (showValue()) {
  <p class="amount">{{ formGroup.controls.input.value | currency: 'EUR' : 'symbol' : '1.2-2' }}</p>
}

@if (showShimmering()) {
  <div class="shimmering">
    <p>Soit&nbsp;</p>
    <neo-shimmering
      [shape]="'line'"
      aria-label="Chargement en cours"
      class="shimmering-data-line"
    />
    <p>&nbsp;parts sociales</p>
  </div>
}

<lib-information-prompt-layout
  [description]="
    'header.description' | wording : {
      wording: template,
      replacement: {
        SHARE_AMOUNT: data?.shareAmount | currency: 'EUR' : 'symbol' : '1.2-2'
      }
    }"
  [title]="titleKey() | wording : {
    wording: template,
    replacement: {
      MAX_AMOUNT: selectedShareAmount()
    }
  }"
>
  <div class="container">
    <form [formGroup]="formGroup">
      <neo-input-amount
        (blur)="onValueBlur()"
        (focus)="onInputFocus()"
        (clear)="clear()"
        [precision]="precision()"
        [size]="'l'"
        class="neo-slider-with-input"
        formControlName="input"
        label="Montant"
      >
        @if (helperState().display) {
          <neo-text-helper type="warning" [iconAriaLabel]="'Avertissement'">
            {{
              helperState().key | wording: {
                wording: template,
                replacement: {
                  HELPER_AMOUNT: helperState().amount | currency: 'EUR' : 'symbol' : '1.2-2'
                }
              }
            }}
          </neo-text-helper>
        } @else {
          <neo-text-helper type="default" [iconAriaLabel]="'Information'">
            {{
              'form.helper.infoAmount'| wording: {
                wording: template,
                replacement: {
                  SHARE_AMOUNT: data?.shareAmount | currency: 'EUR' : 'symbol' : '1.2-2'
                }
              }
            }}
          </neo-text-helper>
        }
      </neo-input-amount>
    </form>

    <neo-slider
      (valueChange)="onSliderChange($event)"
      [ariaLabel]="' '"
      [maxLabel]="' '"
      [max]="data?.maxAmount ?? 0"
      [minLabel]="' '"
      [min]="data?.miniAmount ?? 0"
      [precision]="2"
      [step]="data?.shareAmount ?? 0"
      [value]="formGroup.controls.input.value ?? 0"
    />

    <div class="helpers">
      <neo-text-helper type="default">
        {{ data?.miniAmount | currency: 'EUR' : 'symbol' : '1.2-2' }}
      </neo-text-helper>
      <neo-text-helper type="default">
        {{ data?.maxAmount | currency: 'EUR' : 'symbol' : '1.2-2' }}
      </neo-text-helper>
      <neo-text-helper type="default">
        {{
          'form.helper.shareSlider'| wording: {
            wording: template,
            replacement: {
              NUMBER_SHARE: data?.minParts
            }
          }
        }}
      </neo-text-helper>
      <neo-text-helper type="default">
        {{
          'form.helper.shareSlider'| wording: {
            wording: template,
            replacement: {
              NUMBER_SHARE: data?.maxParts
            }
          }
        }}
      </neo-text-helper>
    </div>

    <div neoCard>
      <div class="slot-content">
        <p class="info-title">{{ template.infobox.title }}</p>
        <p class="bullet">{{ template.infobox.bullet1 }}</p>

        @if (supportsPdfViewer()) {
          <button
            class="download"
            neoButton
            [variant]="'secondary-outline'"
            [iconPosition]="'right'"
            [icon]="'download'"
            aria-haspopup="dialog"
            (click)="openTechnicalNotice()"
          >
            {{ template.infobox.download }}
          </button>
        } @else {
          <a
            class="download"
            neoButton
            [iconPosition]="'right'"
            [variant]="'secondary-outline'"
            [icon]="'download'"
            [href]="getNoticeLink()"
            target="_blank"
            rel="noopener noreferrer"
          >
            {{ template.infobox.download }}
          </a>
        }

        <p class="bullet">{{ template.infobox.bullet2 }}</p>
      </div>
    </div>
  </div>

  <div cta>
    <div [alignment]="'block'" neoButtonGroup>
      <button neoButton alignment="block" (click)="onContinue()">
        {{ template.action }}
      </button>
    </div>
  </div>
</lib-information-prompt-layout>



