import {
  ChangeDetectionStrategy,
  Component,
  DestroyRef,
  OnInit,
  computed,
  effect,
  inject,
  signal,
  untracked,
} from '@angular/core';
import { CurrencyPipe } from '@angular/common';
import { Router } from '@angular/router';
import {
  FormControl,
  FormGroup,
  ReactiveFormsModule,
  Validators,
} from '@angular/forms';
import { takeUntilDestroyed, toSignal } from '@angular/core/rxjs-interop';
import { switchMap } from 'rxjs';

import { NeoTextHelperComponent } from '@bpce/neo-ng/text-helper';
import { InformationPromptLayoutComponent } from '@bpce/ng-subscription-ui/information-prompt-layout';
import { NeoButtonComponent, NeoButtonGroupComponent } from '@bpce/neo-ng/button';
import { NeoSliderComponent } from '@bpce/neo-ng/slider';
import { NeoCardComponent } from '@bpce/neo-ng/card';
import { NeoDialogModule, NeoDialogService } from '@bpce/neo-ng/dialog';
import { NeoInputAmountComponent } from '@bpce/neo-ng/input-amount';
import { NeoShimmeringComponent } from '@bpce/neo-ng/shimmering';

import { StepRouteEnum } from '@app/routes';
import { BapiStoreService } from '@app/services/store/bapi.store.service';
import { InputStoreService } from '@app/services/store/input.store.service';
import { DigitalParameters } from '@app/models/digital-parameters';
import { SAISIE_PART_PAGE_DATALAYER } from '@app/constants/tracking/tracking.constant';
import { TrackingService } from '@bpce/ng-subscription-services/tracking';
import { BapiStore } from '@bpce/ng-subscription-services/bapi/store';
import { NestedKeys, WordingPipe } from '@bpce/ng-subscription-ui/utils';

import { PdfViewModalComponent } from '../modals/pdf-view-modal/pdf-view.modal.component';
import { UpdateAmountModalComponent } from '../modals/update-amount-modal/update-amount.modal.component';
import { SAISIE_PARTS_WORDING } from '@app/constants/wording/saisie-parts-wording.constant';

type WordingKey = NestedKeys<typeof SAISIE_PARTS_WORDING>;

interface ShareData {
  shareAmount: number;
  minAmount: number;
  maxAmount: number;
  selectableMaxAmount: number;
  minParts: number;
  maxParts: number;
  maximumAllowedAmount: number;
  maximumAllowedParts: number;
}

interface HelperState {
  type: 'default' | 'warning';
  key: WordingKey;
  amount: number;
}

@Component({
  selector: 'app-saisie-parts',
  standalone: true, // a retirer si le composant est declare dans un NgModule
  templateUrl: './saisie-parts.component.html',
  styleUrl: './saisie-parts.component.scss',
  changeDetection: ChangeDetectionStrategy.OnPush,
  imports: [
    InformationPromptLayoutComponent,
    NeoButtonComponent,
    NeoButtonGroupComponent,
    NeoSliderComponent,
    NeoTextHelperComponent,
    ReactiveFormsModule,
    NeoCardComponent,
    NeoDialogModule,
    NeoInputAmountComponent,
    WordingPipe,
    CurrencyPipe,
    NeoShimmeringComponent,
  ],
})
export class SaisiePartsComponent implements OnInit {
  readonly template = SAISIE_PARTS_WORDING;

  protected readonly isInputFocused = signal(false);
  protected readonly showShimmering = signal(false);

  private readonly hasUserInteracted = signal(false);
  private readonly lastEnteredAmount = signal<number | null>(null);
  private readonly initialized = signal(false);

  private readonly centRatio = 100;

  private readonly trackingService = inject(TrackingService);
  private readonly neoDialog = inject(NeoDialogService);
  private readonly destroyRef = inject(DestroyRef);
  private readonly router = inject(Router);
  private readonly bapiStore = inject(BapiStoreService);
  private readonly inputStore = inject(InputStoreService);
  private readonly bapiStoreParam: BapiStore<DigitalParameters> = inject(BapiStore);

  protected readonly supportsPdfViewer =
    typeof navigator !== 'undefined' &&
    'pdfViewerEnabled' in navigator &&
    Boolean((navigator as Navigator & { pdfViewerEnabled?: boolean }).pdfViewerEnabled);

  readonly formGroup = new FormGroup({
    input: new FormControl<number | null>(null, {
      validators: [Validators.required, Validators.min(0.01)],
    }),
  });

  private readonly amountControl = this.formGroup.controls.input;

  readonly amountValue = toSignal(this.amountControl.valueChanges, {
    initialValue: this.amountControl.value,
  });

  readonly shareData = computed<ShareData | null>(() => {
    const condition = this.bapiStore.conditionSocialShare.value();
    const selectedAccount = this.bapiStore.selectedAccount();
    const balance = this.inputStore.accountSelected()?.balance ?? null;

    if (!condition || !selectedAccount) {
      return null;
    }

    const shareAmount = selectedAccount.shareAmount.value;
    const minParts = condition.characteristics.minimumShareNumber;
    const maxAmount = condition.characteristics.remainingAmountToInvest.value;
    const maxParts = Math.floor(maxAmount / shareAmount);

    if (maxParts < minParts) {
      return null;
    }

    const maximumAllowedParts =
      balance != null ? Math.max(0, Math.floor(balance / shareAmount)) : 0;

    return {
      shareAmount,
      minParts,
      maxParts,
      minAmount: minParts * shareAmount,
      maxAmount,
      selectableMaxAmount: maxParts * shareAmount,
      maximumAllowedParts,
      maximumAllowedAmount: maximumAllowedParts * shareAmount,
    };
  });

  readonly noticeLink = computed(() => {
    return this.bapiStoreParam.digitalParameters.value()?.links.technicalNoticeLink ?? null;
  });

  readonly normalizedAmount = computed<number | null>(() => {
    const data = this.shareData();
    const amount = this.amountValue();

    if (!data || amount == null || Number.isNaN(amount)) {
      return null;
    }

    return this.normalizeAmount(amount, data);
  });

  readonly displayAmount = computed<number | null>(() => {
    const raw = this.amountValue();
    const normalized = this.normalizedAmount();

    if (this.showShimmering() && raw != null && !Number.isNaN(raw)) {
      return raw;
    }

    return normalized;
  });

  readonly selectedShareCount = computed(() => {
    const data = this.shareData();
    const amount = this.normalizedAmount();

    if (!data || amount == null) {
      return 0;
    }

    return Math.round(this.toCents(amount) / this.toCents(data.shareAmount));
  });

  readonly precision = computed(() => {
    const amount = this.normalizedAmount();
    return !this.isInputFocused() && amount != null && Number.isInteger(amount) ? 0 : 2;
  });

  readonly helperState = computed<HelperState>(() => {
    const data = this.shareData();
    const raw = this.lastEnteredAmount();
    const normalized = this.normalizedAmount();

    if (!data || raw == null || normalized == null || !this.hasUserInteracted() || this.showShimmering()) {
      return {
        type: 'default',
        key: 'form.helper.infoAmount',
        amount: data?.shareAmount ?? 0,
      };
    }

    if (raw > data.maxAmount) {
      return {
        type: 'warning',
        key: 'form.helper.infoAmountMax',
        amount: data.selectableMaxAmount,
      };
    }

    if (raw < data.minAmount) {
      return {
        type: 'warning',
        key: 'form.helper.infoAmountMin',
        amount: data.minAmount,
      };
    }

    if (!this.sameAmount(raw, normalized)) {
      return {
        type: 'warning',
        key: 'form.helper.inputErreur',
        amount: data.shareAmount,
      };
    }

    return {
      type: 'default',
      key: 'form.helper.infoAmount',
      amount: data.shareAmount,
    };
  });

  readonly titleKey = computed<WordingKey>(() => {
    const data = this.shareData();
    const amount = this.normalizedAmount();

    if (!data || amount == null || !this.hasUserInteracted()) {
      return 'header.title.default';
    }

    if (this.showShimmering()) {
      return 'header.title.editedShimmering';
    }

    return this.sameAmount(amount, data.minAmount)
      ? 'header.title.default'
      : 'header.title.edited';
  });

  readonly canContinue = computed(() => {
    const data = this.shareData();
    const raw = this.amountValue();
    return !!data && raw != null && raw > 0 && this.formGroup.valid;
  });

  constructor() {
    effect(
      () => {
        const data = this.shareData();

        if (!data || this.initialized()) {
          return;
        }

        const storedShareNumber = this.inputStore.shareNumber() ?? 0;
        const initialAmount =
          storedShareNumber > 0
            ? this.normalizeAmount(storedShareNumber * data.shareAmount, data)
            : data.minAmount;

        untracked(() => {
          this.formGroup.reset({ input: initialAmount });
          this.lastEnteredAmount.set(initialAmount);
          this.hasUserInteracted.set(storedShareNumber > 0);

          if (storedShareNumber > 0) {
            this.amountControl.markAsDirty();
          }

          this.initialized.set(true);
        });
      },
      { allowSignalWrites: true }
    );
  }

  ngOnInit(): void {
    this.trackingService.trackPage(SAISIE_PART_PAGE_DATALAYER);
  }

  onInputFocus(): void {
    this.isInputFocused.set(true);
  }

  onInputChange(event: Event): void {
    this.showShimmering.set(true);
    this.hasUserInteracted.set(true);
    this.lastEnteredAmount.set(this.parseAmount(event) ?? this.amountControl.value);
  }

  onInputBlur(): void {
    this.isInputFocused.set(false);
    this.showShimmering.set(false);

    const data = this.shareData();
    const raw = this.amountControl.value;

    this.lastEnteredAmount.set(raw);

    if (!data || raw == null || Number.isNaN(raw)) {
      return;
    }

    const normalized = this.normalizeAmount(raw, data);

    if (!this.sameAmount(raw, normalized)) {
      this.amountControl.setValue(normalized);
    }

    this.amountControl.markAsDirty();
  }

  onSliderChange(value: number): void {
    const data = this.shareData();

    if (!data) {
      return;
    }

    const normalized = this.normalizeAmount(value, data);

    this.isInputFocused.set(false);
    this.showShimmering.set(false);
    this.hasUserInteracted.set(true);
    this.lastEnteredAmount.set(normalized);

    this.amountControl.setValue(normalized);
    this.amountControl.markAsDirty();
  }

  clear(): void {
    const data = this.shareData();

    if (!data) {
      return;
    }

    this.showShimmering.set(false);
    this.hasUserInteracted.set(false);
    this.lastEnteredAmount.set(data.minAmount);
    this.formGroup.reset({ input: data.minAmount });
  }

  openDefault(): void {
    this.neoDialog
      .open(PdfViewModalComponent)
      .pipe(
        switchMap((ref) => ref.afterClose()),
        takeUntilDestroyed(this.destroyRef)
      )
      .subscribe();
  }

  continue(): void {
    const data = this.shareData();
    const amount = this.normalizedAmount();
    const balance = this.inputStore.accountSelected()?.balance ?? null;

    if (!data || amount == null || !this.canContinue()) {
      return;
    }

    if (balance != null && amount > balance) {
      this.neoDialog
        .open(UpdateAmountModalComponent, {
          data: {
            maximumAllowedAmount: data.maximumAllowedAmount,
            maximumAllowedParts: data.maximumAllowedParts,
          },
        })
        .pipe(
          switchMap((ref) => ref.afterClose()),
          takeUntilDestroyed(this.destroyRef)
        )
        .subscribe();

      return;
    }

    this.inputStore.setShareNumberSelected(this.selectedShareCount());
    this.router.navigate([StepRouteEnum.QUESTION_INTRO]);
  }

  private normalizeAmount(value: number, data: ShareData): number {
    const clamped = Math.min(Math.max(value, data.minAmount), data.maxAmount);
    const shareAmountInCents = this.toCents(data.shareAmount);

    let shareCount = Math.round(this.toCents(clamped) / shareAmountInCents);
    shareCount = Math.min(Math.max(shareCount, data.minParts), data.maxParts);

    return this.fromCents(shareCount * shareAmountInCents);
  }

  private parseAmount(event: Event): number | null {
    const rawValue = (event.target as HTMLInputElement | null)?.value ?? '';
    const normalizedValue = rawValue.replace(/\s/g, '').replace(',', '.');
    const parsed = Number.parseFloat(normalizedValue);

    return Number.isFinite(parsed) ? parsed : null;
  }

  private sameAmount(a: number, b: number): boolean {
    return this.toCents(a) === this.toCents(b);
  }

  private toCents(amount: number): number {
    return Math.round(amount * this.centRatio);
  }

  private fromCents(amountInCents: number): number {
    return amountInCents / this.centRatio;
  }
}




@if (showValue()) {
  <p class="amount">{{ displayAmount() | currency: 'EUR' : 'symbol' : '1.2-2' }}</p>
}

@if (showShimmering()) {
  <div class="shimmering">
    <p>Soit&nbsp;</p>
    <neo-shimmering
      [shape]="'line'"
      aria-label="Chargement en cours"
      class="shimmering-data-line"
    />
    <p>&nbsp;parts sociales</p>
  </div>
}

<lib-information-prompt-layout
  [description]="
    'header.description'
      | wording
        : {
            wording: template,
            replacement: {
              SHARE_AMOUNT:
                shareData()?.shareAmount | currency: 'EUR' : 'symbol' : '1.2-2',
            },
          }
  "
  [title]="
    titleKey()
      | wording
        : {
            wording: template,
            replacement: { PART_COUNT: selectedShareCount() },
          }
  "
>
  <div class="container">
    <form [formGroup]="formGroup">
      <neo-input-amount
        formControlName="input"
        class="neo-slider-with-input"
        label="Montant"
        [size]="'l'"
        [precision]="precision()"
        (focus)="onInputFocus()"
        (input)="onInputChange($event)"
        (blur)="onInputBlur()"
        (clear)="clear()"
      >
        @if (helperState().type === 'warning') {
          <neo-text-helper type="warning" [iconAriaLabel]="'warning'">
            {{
              helperState().key
                | wording
                  : {
                      wording: template,
                      replacement: {
                        HELPER_AMOUNT:
                          helperState().amount | currency: 'EUR' : 'symbol' : '1.2-2',
                      },
                    }
            }}
          </neo-text-helper>
        } @else {
          <neo-text-helper type="default" [iconAriaLabel]="'default'">
            {{
              'form.helper.infoAmount'
                | wording
                  : {
                      wording: template,
                      replacement: {
                        SHARE_AMOUNT:
                          shareData()?.shareAmount | currency: 'EUR' : 'symbol' : '1.2-2',
                      },
                    }
            }}
          </neo-text-helper>
        }
      </neo-input-amount>
    </form>

    <neo-slider
      [ariaLabel]="''"
      [min]="shareData()?.minAmount ?? 0"
      [max]="shareData()?.selectableMaxAmount ?? 0"
      [step]="shareData()?.shareAmount ?? 0"
      [precision]="2"
      [minLabel]="' '"
      [maxLabel]="' '"
      [value]="normalizedAmount() ?? 0"
      (valueChange)="onSliderChange($event)"
    />

    <div class="helpers">
      <neo-text-helper type="default">
        {{ shareData()?.minAmount | currency: 'EUR' : 'symbol' : '1.2-2' }}
      </neo-text-helper>

      <neo-text-helper type="default">
        {{ shareData()?.selectableMaxAmount | currency: 'EUR' : 'symbol' : '1.2-2' }}
      </neo-text-helper>

      <neo-text-helper type="default">
        {{
          'form.helper.shareSlider'
            | wording
              : {
                  wording: template,
                  replacement: { NUMBER_SHARE: shareData()?.minParts },
                }
        }}
      </neo-text-helper>

      <neo-text-helper type="default">
        {{
          'form.helper.shareSlider'
            | wording
              : {
                  wording: template,
                  replacement: { NUMBER_SHARE: shareData()?.maxParts },
                }
        }}
      </neo-text-helper>
    </div>

    <div neoCard>
      <div class="slot-content">
        <p class="info-title">{{ template.infobox.title }}</p>
        <p class="bullet">{{ template.infobox.bullet1 }}</p>

        @if (supportsPdfViewer) {
          <button
            class="download"
            neoButton
            [variant]="'secondary-outline'"
            [iconPosition]="'right'"
            [icon]="'download'"
            aria-haspopup="dialog"
            (click)="openDefault()"
          >
            {{ template.infobox.download }}
          </button>
        } @else {
          <a
            class="download"
            neoButton
            [variant]="'secondary-outline'"
            [iconPosition]="'right'"
            [icon]="'download'"
            [href]="noticeLink()"
          >
            {{ template.infobox.download }}
          </a>
        }

        <p class="bullet">{{ template.infobox.bullet2 }}</p>
      </div>
    </div>
  </div>

  <div cta>
    <div neoButtonGroup [alignment]="'block'">
      <button neoButton alignment="block" (click)="continue()" [disabled]="!canContinue()">
        {{ template.action }}
      </button>
    </div>
  </div>
</lib-information-prompt-layout>



